    <section id="contato" class="section section-contact" aria-labelledby="contato-title">
      <div class="container contact-grid">
        <div class="contact-copy">
          <h2 id="contato-title" class="section-title">Mapeie seus processos e aumente a eficiência da sua empresa em até 30%</h2>
          <p>
            Descubra onde sua operação perde eficiência e transforme falhas invisíveis em oportunidades reais de crescimento, com mais controle, produtividade e escala.
          </p>
          <p class="contact-official">
            <a href="https://www.itajr.com.br/" rel="noopener noreferrer">Site oficial: itajr.com.br</a>
          </p>
        </div>
        <form class="contact-form" id="form-contato" action="#" method="post" novalidate>
          <label class="field">
            <span>Nome</span>
            <input type="text" name="nome" id="nome" required autocomplete="name" />
          </label>
          <label class="field">
            <span>Email</span>
            <input type="email" name="email" id="email" required autocomplete="email" />
          </label>
          <label class="field">
            <span>Whatsapp</span>
            <input type="tel" name="whatsapp" id="whatsapp" autocomplete="tel" placeholder="(00) 00000-0000" />
          </label>
          <label class="field">
            <span>Quanto Você pretende Investir em seu projeto?</span>
            <select name="investimento" id="investimento">
              <option value="">Selecione um valor...</option>
              <option value="Até R$ 15.000">Até R$ 15.000</option>
              <option value="R$ 15.000 a R$ 40.000">R$ 15.000 a R$ 40.000</option>
              <option value="R$ 40.000 a R$ 100.000">R$ 40.000 a R$ 100.000</option>
              <option value="Acima de R$ 100.000">Acima de R$ 100.000</option>
              <option value="A definir com consultoria">A definir com consultoria</option>
            </select>
          </label>
          <label class="field">
            <span>Em qual etapa do processo você precisa de apoio?</span>
            <select name="area" id="area">
              <option value="">Selecione uma etapa...</option>
              <option value="Diagnóstico e entendimento do negócio">Diagnóstico e entendimento do negócio</option>
              <option value="Mapeamento dos processos atuais">Mapeamento dos processos atuais</option>
              <option value="Análise e identificação de otimizações">Análise e identificação de otimizações</option>
              <option value="Redesenho e plano de ação">Redesenho e plano de ação</option>
            </select>
          </label>
          <label class="field field--full">
            <span>Descreva seu projeto</span>
            <textarea name="mensagem" id="mensagem" rows="4" required placeholder="Descreva seu projeto"></textarea>
          </label>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary btn-block">Enviar</button>
          </div>
          <p class="form-note" id="form-feedback" role="status" aria-live="polite"></p>
        </form>
