  <title>Ita Júnior — Empresa júnior do ITA</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="static/styles.css" />
</head>
<body>
  <a class="skip-link" href="#conteudo-principal">Ir para o conteúdo</a>

  <header class="site-header">
    <div class="container header-inner">
      <a href="https://www.itajr.com.br/" class="logo" aria-label="Ita Júnior — início">
        <img src="static/ita-junior-logo.png" alt="Logo ITA Júnior Consultoria Tecnológica" class="logo-image" />
