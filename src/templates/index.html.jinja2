  <script>
    document.getElementById("year").textContent = new Date().getFullYear();
    (function () {
      var toggle = document.querySelector(".nav-toggle");
      var menu = document.getElementById("nav-menu");
      if (!toggle || !menu) return;
      toggle.removeAttribute("hidden");
      toggle.addEventListener("click", function () {
        var open = menu.classList.toggle("is-open");
        toggle.setAttribute("aria-expanded", open ? "true" : "false");
      });
    })();
    (function () {
      var stats = document.querySelectorAll(".stat-num[data-count]");
      if (!stats.length || !("IntersectionObserver" in window)) {
        stats.forEach(function (el) {
          var t = el.getAttribute("data-count");
          if (t !== null) el.textContent = t;
        });
        return;
      }
      var done = false;
      var obs = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (!entry.isIntersecting || done) return;
            done = true;
            stats.forEach(function (el) {
              var target = parseInt(el.getAttribute("data-count"), 10);
              var start = 0;
              var dur = 1200;
              var t0 = null;
              function step(ts) {
                if (!t0) t0 = ts;
                var p = Math.min((ts - t0) / dur, 1);
                el.textContent = Math.floor(start + (target - start) * p);
                if (p < 1) requestAnimationFrame(step);
              }
              requestAnimationFrame(step);
            });
            obs.disconnect();
          });
        },
        { threshold: 0.25 }
      );
      obs.observe(document.getElementById("resultados"));
    })();
    (function () {
      var GOOGLE_APPS_SCRIPT_URL = "https://script.google.com/macros/s/AKfycbyGRmLYdemi_k02PlDmtAb5iH6ZTwGvIsgb7-gBO-is1TdGD55fQ7I7pNan3PnD-eBi/exec";
      var form = document.getElementById("form-contato");
      var feedback = document.getElementById("form-feedback");
      if (!form) return;
      form.addEventListener("submit", async function (e) {
        e.preventDefault();
        var nome = document.getElementById("nome").value.trim();
        var email = document.getElementById("email").value.trim();
        var wa = document.getElementById("whatsapp").value.trim();
        var inv = document.getElementById("investimento").value;
        var area = document.getElementById("area").value;
        var msg = document.getElementById("mensagem").value.trim();
        if (!nome || !email || !msg) {
          feedback.textContent = "Preencha nome, email e a descrição do projeto.";
          return;
        }
        if (!GOOGLE_APPS_SCRIPT_URL || GOOGLE_APPS_SCRIPT_URL.indexOf("COLE_AQUI_") === 0) {
          feedback.textContent = "Configuração pendente: cole a URL do Web App do Google Apps Script.";
          return;
        }
        var payload = {
          submitted_at: new Date().toISOString(),
          page_url: window.location.href,
          user_agent: window.navigator.userAgent,
          nome: nome,
          email: email,
          whatsapp: wa || "",
          investimento: inv || "",
          etapa_processo: area || "",
          mensagem: msg
        };
        function toPublicAppsScriptUrl(url) {
          return String(url || "").replace(
            /https:\/\/script\.google\.com\/a\/macros\/[^/]+\/s\//,
            "https://script.google.com/macros/s/"
          );
        }
        var endpoint = toPublicAppsScriptUrl(GOOGLE_APPS_SCRIPT_URL);
        feedback.textContent = "Enviando seus dados...";
        var submitBtn = form.querySelector("button[type='submit']");
        if (submitBtn) submitBtn.disabled = true;
        try {
          await fetch(endpoint, {
            method: "POST",
            mode: "no-cors",
            headers: { "Content-Type": "text/plain;charset=utf-8" },
            body: JSON.stringify(payload)
          });
          feedback.textContent = "Recebemos seu contato! Em breve nossa equipe retorna.";
          form.reset();
        } catch (err) {
          feedback.textContent = "Nao foi possivel enviar agora. Tente novamente em instantes.";
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    })();
  </script>
